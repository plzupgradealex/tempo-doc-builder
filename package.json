{
  "name": "tempo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "LCARS-styled agenda builder for consultant trips and client meetings",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "deploy": "npm run build && wrangler pages deploy dist --project-name tempo"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/file-saver": "^2.0.7",
    "jsdom": "^26.0.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "docx": "^9.5.3",
    "file-saver": "^2.0.5",
    "jspdf": "^4.2.0"
  }
}
